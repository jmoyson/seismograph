# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=seismo
DB_PASSWORD=changeme
DB_NAME=seismograph

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
PORT=3000

# USGS
USGS_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/2.5_hour.geojson
USGS_SEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/2.5_month.geojson

# Superset
SUPERSET_SECRET_KEY=change_me_to_a_long_random_string
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@seismograph.local
# Override the image tag if you want to pin a specific build (default: :latest from GHCR)
# SUPERSET_IMAGE=ghcr.io/jmoyson/seismograph-superset:latest
# SUPERSET_VERSION only matters for local rebuilds (`docker compose build superset`)
# SUPERSET_VERSION=6.0.0
